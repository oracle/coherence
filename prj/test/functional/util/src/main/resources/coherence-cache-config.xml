<!--
Cache Configuration used for the util test suite.
-->
<cache-config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xmlns="http://xmlns.oracle.com/coherence/coherence-cache-config"
              xsi:schemaLocation="http://xmlns.oracle.com/coherence/coherence-cache-config coherence-cache-config.xsd">

  <caching-scheme-mapping>
    <cache-mapping>
      <cache-name>*</cache-name>
      <scheme-name>none</scheme-name>
    </cache-mapping>
  </caching-scheme-mapping>

  <caching-schemes>
    <invocation-scheme>
      <service-name>vdp-backpressure</service-name>
      <daemon-pool>virtual</daemon-pool>
      <task-limit>8</task-limit>
      <autostart>true</autostart>
    </invocation-scheme>

    <invocation-scheme>
      <service-name>invocation</service-name>
      <daemon-pool system-property="coherence.test.daemonpool">platform</daemon-pool>
    </invocation-scheme>
  </caching-schemes>
</cache-config>
